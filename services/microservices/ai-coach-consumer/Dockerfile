FROM golang:1.23-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /ai-coach-consumer ./services/microservices/ai-coach/consumer

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /ai-coach-consumer /usr/local/bin/
ENTRYPOINT ["ai-coach-consumer"]
